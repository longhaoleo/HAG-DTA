\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Illustration of the main feature extraction modules in HAG-DTA. (a) The DGNN module extracts global topological features from the original drug molecular graph. (b) Drug SMILES strings are converted into molecular graphs using RDKit. (c) The HGNN module performs hierarchical graph pooling to obtain the coarsened graphs $G^{(1)}$ and $G^{(2)}$, from which $X_{H_1}$ and $X_{H_2}$ are extracted. (d) The CNN module extracts local sequence features from protein sequences.}}{13}{figure.caption.4}\protected@file@percent }
\newlabel{fig2}{{2}{13}{Illustration of the main feature extraction modules in HAG-DTA. (a) The DGNN module extracts global topological features from the original drug molecular graph. (b) Drug SMILES strings are converted into molecular graphs using RDKit. (c) The HGNN module performs hierarchical graph pooling to obtain the coarsened graphs $G^{(1)}$ and $G^{(2)}$, from which $X_{H_1}$ and $X_{H_2}$ are extracted. (d) The CNN module extracts local sequence features from protein sequences}{figure.caption.4}{}}
\newlabel{eq:protein_output}{{11}{13}{Protein sequence feature extraction module}{equation.11}{}}
