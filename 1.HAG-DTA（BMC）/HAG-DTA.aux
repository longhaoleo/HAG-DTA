\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Model interpretation examples of HAG-DTA. The left panel shows the molecular clustering results learned by the HGNN module. The first-layer clusters correspond to local substructures, while the second-layer clusters represent larger molecular fragments obtained by further graph coarsening. The right panel shows the atom-level attention scores generated by the DGNN module. These visualization results provide structural cues for understanding model predictions.}}{32}{figure.caption.22}\protected@file@percent }
\newlabel{fig4}{{5}{32}{Model interpretation examples of HAG-DTA. The left panel shows the molecular clustering results learned by the HGNN module. The first-layer clusters correspond to local substructures, while the second-layer clusters represent larger molecular fragments obtained by further graph coarsening. The right panel shows the atom-level attention scores generated by the DGNN module. These visualization results provide structural cues for understanding model predictions}{figure.caption.22}{}}
